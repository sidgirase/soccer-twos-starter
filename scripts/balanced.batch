#!/bin/bash
#SBATCH --job-name=soc_bal_fst
#SBATCH --nodes=1
#SBATCH --cpus-per-task=12        
#SBATCH --mem=16G               
#SBATCH --time=12:00:00
#SBATCH --partition=ice-cpu      
#SBATCH --output=slurm_bal_fst_%j.out
#SBATCH --mail-type=BEGIN,END,FAIL
#SBATCH --mail-user=sgirase3@gatech.edu

cd ~/scratch/v2/soccer-twos-starter

module purge
module load anaconda3/2023.03
source activate soccertwos

export RAY_DISABLE_DASHBOARD=1
TIMESTAMP=$(date +"%b%d_%H%M")

# High learning rate but strict clipping so it learns quickly 
# without accidentally destroying the policy weights.
echo "Starting Balanced From 300th Checkpoint.."
python train_final_agent.py \
    --strategy balanced \
    --workers 32 \
    --iters 3750 \
    --lr 5e-4 \
    --clip 0.1 \
    --name "Balanced_Fast_Resumed" \
    --restore "/home/hice1/sgirase3/scratch/v2/soccer-twos-starter/ray_results/Balanced_Fast_Resumed/PPO_ShapedSoccer_f4f48_00000_0_2026-04-24_22-39-18/checkpoint_001550/checkpoint-1550"